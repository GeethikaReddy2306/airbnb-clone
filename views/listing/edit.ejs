<% layout('layouts/boilerplate') %>
<body>

<h1>Edit Listing</h1>

<form action="/listing/<%= listing._id %>?_method=PUT" method="POST">

    <input type="text" name="title" value="<%= listing.title %>" placeholder="title">

    <input type="text" name="description" value="<%= listing.description %>" placeholder="description">

    <input type="number" name="price" value="<%= listing.price %>" placeholder="price">

    <input type="text" name="location" value="<%= listing.location %>" placeholder="location">

    <input type="text" name="country" value="<%= listing.country %>" placeholder="country">

    <button type="submit">Update</button>

</form>

</body>
