<% layout('layouts/boilerplate') %>
<section class="row justify-content-center">
  <div class="col-12 col-lg-10 col-xl-8">
    <div class="form-shell">
      <div class="mb-4">
        <span class="eyebrow-text">Host dashboard</span>
        <h1 class="page-title mt-2 mb-2">Edit listing</h1>
        <p class="page-subtitle mb-0">Refresh the content and visuals to keep your listing polished and guest-ready.</p>
      </div>

      <form action="/listing/<%= listing._id %>?_method=PUT" method="POST" class="listing-form">
        <div class="row g-4">
          <div class="col-12">
            <label for="title" class="form-label">Listing title</label>
            <input type="text" class="form-control" id="title" name="title" value="<%= listing.title %>" placeholder="Listing title" required>
          </div>

          <div class="col-12">
            <label for="description" class="form-label">Description</label>
            <textarea class="form-control" id="description" name="description" rows="5" placeholder="Description" required><%= listing.description %></textarea>
          </div>

          <div class="col-12">
            <label for="imageUrl" class="form-label">Image URL</label>
            <input type="url" class="form-control" id="imageUrl" name="imageUrl" value="<%= listing.image && listing.image.url ? listing.image.url : '' %>" placeholder="https://images.unsplash.com/..." required>
          </div>

          <div class="col-12 col-md-6">
            <label for="location" class="form-label">Location</label>
            <input type="text" class="form-control" id="location" name="location" value="<%= listing.location %>" placeholder="Location" required>
          </div>

          <div class="col-12 col-md-6">
            <label for="country" class="form-label">Country</label>
            <input type="text" class="form-control" id="country" name="country" value="<%= listing.country %>" placeholder="Country" required>
          </div>

          <div class="col-12 col-md-6">
            <label for="price" class="form-label">Price per night</label>
            <div class="input-group">
              <span class="input-group-text">₹</span>
              <input type="number" class="form-control" id="price" name="price" value="<%= listing.price %>" placeholder="Price per night" required step="0.01">
            </div>
          </div>

          <div class="col-12 col-md-6 d-flex align-items-end">
            <button type="submit" class="btn btn-airbnb w-100 py-3">Update Listing</button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>
