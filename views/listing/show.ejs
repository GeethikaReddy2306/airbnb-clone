<% layout('layouts/boilerplate') %>
<section class="mb-4">
  <div class="row g-4">
    <div class="col-12 col-lg-8">
      <span class="eyebrow-text">Featured stay</span>
      <h1 class="page-title mt-2 mb-2"><%= place.title %></h1>
      <div class="d-flex flex-wrap align-items-center gap-3 listing-meta">
        <span class="listing-meta__rating"><i class="fa-solid fa-star"></i> 4.8</span>
        <span class="listing-meta__dot"></span>
        <span><%= place.location %>, <%= place.country %></span>
      </div>
    </div>
    <div class="col-12 col-lg-4">
      <div class="detail-price-card ms-lg-auto">
        <span class="detail-price-card__label">Price per night</span>
        <div class="detail-price-card__value">₹<%= place.price %></div>
      </div>
    </div>
  </div>
</section>

<section class="row g-4 mb-4">
  <div class="col-12 col-lg-8">
    <div class="detail-media-card">
      <% if (place.image && place.image.url) { %>
        <img src="<%= place.image.url %>" alt="<%= place.title %>" class="detail-hero-image">
      <% } else { %>
        <div class="detail-hero-placeholder d-flex align-items-center justify-content-center">
          <div class="text-center">
            <i class="fa-regular fa-image mb-3"></i>
            <p class="mb-0">Add an image URL to give this stay a polished Airbnb-style preview.</p>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="col-12 col-lg-4">
    <div class="detail-side-card h-100">
      <h2 class="h5 mb-3">Stay details</h2>
      <div class="detail-stat">
        <span class="detail-stat__label">Location</span>
        <span class="detail-stat__value"><%= place.location %>, <%= place.country %></span>
      </div>
      <div class="detail-stat">
        <span class="detail-stat__label">Nightly rate</span>
        <span class="detail-stat__value">₹<%= place.price %></span>
      </div>
      <div class="detail-stat">
        <span class="detail-stat__label">Guest rating</span>
        <span class="detail-stat__value"><i class="fa-solid fa-star text-danger me-1"></i>4.8 / 5</span>
      </div>
    </div>
  </div>
</section>

<section class="row g-4">
  <div class="col-12 col-lg-8">
    <div class="detail-content-card">
      <h2 class="h4 mb-3">About this place</h2>
      <p class="listing-description mb-0"><%= place.description %></p>
    </div>
  </div>

  <div class="col-12 col-lg-4">
    <div class="detail-content-card">
      <h2 class="h5 mb-3">Host actions</h2>
      <div class="d-grid gap-3">
        <a href="/listing/<%= place._id %>/edit" class="btn btn-airbnb-outline py-3">Edit Listing</a>
        <form action="/listing/<%= place._id %>?_method=DELETE" method="POST" class="m-0">
          <button
            type="submit"
            class="btn btn-airbnb py-3 w-100"
            onclick="return confirm('Are you sure you want to delete this listing?')"
          >
            Delete Listing
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
